# Lens web — environment variables
# Copy to .env.local for local dev.

# Supabase (public values are exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787

# Stripe publishable key — used by the embedded <PaymentElement> on
# /billing/checkout. Test-mode (`pk_test_…`) is fine for dev.
# dashboard.stripe.com → Developers → API keys → Publishable key.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
