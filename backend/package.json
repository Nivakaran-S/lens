{
  "name": "lens-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lens — UK auction legal-pack analyzer (backend)",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/dev.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/dev.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env scripts/migrate.js",
    "db:retention": "node --env-file=.env scripts/retention.js"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@hono/node-server": "^1.13.0",
    "@node-rs/argon2": "^2.0.2",
    "adm-zip": "^0.5.16",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.7",
    "stripe": "^17.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
