{
  "name": "lens-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lens — UK auction legal-pack analyzer (backend)",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/dev.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/dev.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@google/genai": "^1.0.0",
    "@hono/node-server": "^1.13.0",
    "adm-zip": "^0.5.16",
    "hono": "^4.6.0",
    "inngest": "^3.27.0",
    "jose": "^5.9.0",
    "mongodb": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
