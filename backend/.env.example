# Lens API — environment variables (Plesk deployment)
# Copy to .env for local dev (loaded by `npm run dev` via --env-file=.env).
# On Plesk, set these in the Node.js app's Environment tab or via SSH.

# ── Supabase (auth only — JWT verification, no SDK calls) ─────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=                            # optional, only if your project uses HS256
SUPABASE_JWT_AUD=authenticated

# ── MariaDB / MySQL (Plesk-managed, localhost) ───────────────────
# Create the DB + user via Plesk → Databases → Add Database (pick MariaDB).
# Plesk MariaDB listens on 3306. URL-encode special chars in the password
# (`#` becomes `%23`, `@` becomes `%40`, etc.).
DATABASE_URL=mysql://lens:<URL_ENCODED_PASSWORD>@localhost:3306/lens

# ── Local file storage (replaces Cloudflare R2) ───────────────────
# Path on the Plesk server where uploaded ZIPs and extracted PDFs live.
# Must be readable+writable by the Node process user; chmod 0700.
# Layout: {UPLOAD_DIR}/{userId}/{jobId}/{filename}.zip and
#         {UPLOAD_DIR}/{userId}/{jobId}/docs/{idx}-{filename}.pdf
UPLOAD_DIR=/var/www/vhosts/yourdomain.com/uploads

# HMAC secret for signing short-lived download URLs.
# Generate with: openssl rand -hex 32   (must be at least 32 chars)
FILE_SIGN_SECRET=

# Download URL TTL in seconds (default 900 = 15 min).
FILE_SIGN_TTL_SECONDS=900

# Public origin used when composing absolute download URLs (the worker has
# no request context to derive this from). Must match how the frontend
# reaches the backend — typically https://api.yourdomain.com.
PUBLIC_API_URL=https://api.yourdomain.com

# ── Google Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Stripe (optional in dev — paid features won't work without these) ────
# Payment is embedded on /billing/checkout via Stripe Elements (PaymentIntents
# API). The publishable key is a FRONTEND env var, not here — set it as
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY in frontend/.env.local.
# Test-mode keys are fine. Get from dashboard.stripe.com → Developers → API keys.
STRIPE_SECRET_KEY=
# Webhook signing secret. The relevant event is `payment_intent.succeeded`.
# Local dev: run `stripe listen --forward-to localhost:8788/api/stripe/webhook`
# and copy the whsec_... it prints. Production: Dashboard → Webhooks → endpoint
# → subscribe to `payment_intent.succeeded` → copy the Signing secret.
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=gbp

# ── Roles + credits policy ────────────────────────────────────────
# Comma-separated list of admin emails. On first sign-in, these users
# are created with role=admin. Other users default to role=user.
ADMIN_EMAILS=
# Free credits granted to a brand-new user on signup.
INITIAL_FREE_CREDITS=10
# Credits charged per pack analysis. Refunded automatically on failure.
COST_PER_ANALYSIS=1

# Frontend URL — kept for future server-side redirects. Embedded checkout
# builds return_url client-side, so this is currently unused.
FRONTEND_URL=http://localhost:3000

# ── CORS — comma-separated frontend origins (no trailing slash) ───
CORS_ORIGINS=https://yourdomain.com,http://localhost:3000
