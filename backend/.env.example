# Lens API — environment variables
# Copy to .env for local dev (loaded by `npm run dev` via --env-file=.env).
# On Render, set these in the dashboard.

# ── Supabase (auth only — JWT verification, no SDK calls) ─────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=                            # optional, only if your project uses HS256
SUPABASE_JWT_AUD=authenticated

# ── MongoDB ─────────────────────────────────────────────────────
# Atlas connection string (mongodb+srv://...) or self-hosted
MONGODB_URL=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=lens

# ── Cloudflare R2 (S3-compatible object storage) ──────────────────
R2_ACCOUNT_ID=                                  # from R2 dashboard URL
R2_ACCESS_KEY_ID=                               # 32-char hex from R2 → Manage R2 API Tokens (S3 section)
R2_SECRET_ACCESS_KEY=
R2_BUCKET=lens-packs                            # bucket name (must exist)

# ── Google Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Stripe (optional in dev — paid features won't work without these) ────
# Payment is embedded on our own /billing/checkout page via Stripe Elements
# (PaymentIntents API). The publishable key is a FRONTEND env var, not here —
# set it as NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY in frontend/.env.local.
# Test-mode keys are fine. Get from dashboard.stripe.com → Developers → API keys.
STRIPE_SECRET_KEY=
# Webhook signing secret. The relevant event is `payment_intent.succeeded`.
# Local dev: run `stripe listen --forward-to localhost:8788/api/stripe/webhook`
# and copy the whsec_... it prints. Production: Dashboard → Webhooks → endpoint
# → subscribe to `payment_intent.succeeded` → copy the Signing secret.
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=gbp

# ── Roles + credits policy ────────────────────────────────────────
# Comma-separated list of admin emails. On first sign-in, these users
# are created with role=admin. Other users default to role=user.
ADMIN_EMAILS=
# Free credits granted to a brand-new user on signup.
INITIAL_FREE_CREDITS=10
# Credits charged per pack analysis. Refunded automatically on failure.
COST_PER_ANALYSIS=1

# Frontend URL — kept for future server-side redirects. Embedded checkout
# builds return_url client-side, so this is currently unused. Safe to leave
# at the default in dev.
FRONTEND_URL=http://localhost:3000

# ── CORS — comma-separated frontend origins (no trailing slash) ───
CORS_ORIGINS=http://localhost:3000
