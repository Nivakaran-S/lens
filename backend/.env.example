# Lens API — environment variables
# Copy to .env.local for local dev (loaded by tsx via --env-file or your shell).

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...                       # public, used to verify JWTs
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # server-only, full DB/storage access
SUPABASE_JWT_AUD=authenticated

# Google Gemini
GEMINI_API_KEY=AIza...

# Inngest (set after creating an Inngest app)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# CORS — comma-separated list of allowed origins for the frontend
CORS_ORIGINS=http://localhost:3000
